---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-brand"><svg width="16" height="16" viewBox="0 0 32 32" fill="none" style="vertical-align: -2px; margin-right: 0.35rem;"><line x1="16" y1="16" x2="7" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/><line x1="16" y1="16" x2="25" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/><line x1="16" y1="16" x2="16" y2="26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/><circle cx="7" cy="8" r="2.5" fill="var(--bg)" stroke="currentColor" stroke-width="1.5"/><circle cx="25" cy="8" r="2.5" fill="var(--bg)" stroke="currentColor" stroke-width="1.5"/><circle cx="16" cy="26" r="2.5" fill="var(--bg)" stroke="currentColor" stroke-width="1.5"/><circle cx="16" cy="16" r="3.5" fill="currentColor"/></svg>KARA LABS</span>
      <span class="footer-copy">© {year}</span>
      <span class="footer-toronto">Made with <span class="heart">♥</span> in Toronto</span>
    </div>
    <div class="footer-links">
      <a href="/rss.xml" class="footer-link">RSS</a>
      <a href="https://linkedin.com/in/utkarshvashisth" target="_blank" rel="noopener" class="footer-link">LinkedIn</a>
      <a href="https://github.com/karalabs-dev" target="_blank" rel="noopener" class="footer-link">GitHub</a>
    </div>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--border); margin-top: 6rem; }
  .footer-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-left { display: flex; align-items: center; gap: 1rem; }
  .footer-brand {

    font-size: var(--font-size-2xs);
    font-weight: 700;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }
  .footer-copy { font-size: var(--font-size-2xs); color: var(--text-dim); }
  .footer-toronto { font-size: var(--font-size-2xs); color: var(--text-dim); }
  .heart { color: #ef4444; }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-link { font-size: var(--font-size-2xs); color: var(--text-dim); transition: color var(--transition); }
  .footer-link:hover { color: var(--text); }
</style>
