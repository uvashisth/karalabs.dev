---
interface Props {
  title: string;
  description: string;
  date: Date;
  formatTag: string;
  topicTag?: string;
  slug: string;
  tags?: string[];
  image?: string;
  readingTime?: number;
}

const { title, description, date, formatTag, topicTag, slug, tags = [], image, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="card">
  {image && (
    <div class="card-image">
      <img src={image} alt={title} loading="lazy" />
    </div>
  )}
  <div class="card-meta">
    <span class="card-category">{formatTag}</span>
    {topicTag && <span class="card-topic">{topicTag}</span>}
    <span class="card-date">{formattedDate}</span>
    {readingTime && <span class="card-read">{readingTime} min</span>}
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  {tags.length > 0 && (
    <div class="card-tags">
      {tags.slice(0, 4).map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  )}
</a>

<style>
  .card-image {
    margin: -1.5rem -1.5rem 1rem;
    overflow: hidden;
    border-radius: var(--radius) var(--radius) 0 0;
  }
  .card-image img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    transition: transform var(--transition);
  }
  .card:hover .card-image img { transform: scale(1.03); }
  .card {
    display: block;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all var(--transition);
    text-decoration: none;
  }
  .card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }
  .card-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
  .card-category {

    font-size: var(--font-size-3xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .card-topic {

    font-size: var(--font-size-3xs);
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--text-dim);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .card-date { font-size: var(--font-size-2xs); color: var(--text-dim); }
  .card-read { font-size: var(--font-size-3xs); color: var(--text-dim); }
  .card-title { font-size: 1.2rem; color: var(--text); margin-bottom: 0.5rem; line-height: var(--line-height-heading); }
  .card-desc {
    font-size: var(--font-size-2xs);
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    line-height: var(--line-height-compact);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag {

    font-size: var(--font-size-3xs);
    color: var(--text-dim);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }
</style>
