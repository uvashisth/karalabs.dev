---
interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  slug: string;
  tags?: string[];
}

const { title, description, date, category, slug, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="card">
  <div class="card-meta">
    <span class="card-category">{category}</span>
    <span class="card-date">{formattedDate}</span>
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  {tags.length > 0 && (
    <div class="card-tags">
      {tags.slice(0, 4).map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  )}
</a>

<style>
  .card {
    display: block;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all var(--transition);
    text-decoration: none;
  }
  .card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }
  .card-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
  .card-category {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .card-date { font-size: 0.8rem; color: var(--text-dim); }
  .card-title { font-size: 1.2rem; color: var(--text); margin-bottom: 0.5rem; line-height: 1.3; }
  .card-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }
</style>
