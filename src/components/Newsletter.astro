<div class="newsletter">
  <h3>Stay in the loop</h3>
  <p>New posts on AI agents, benchmarks, and production systems — no spam.</p>
  <form class="nl-form" id="nl-form">
    <input type="email" name="email_address" placeholder="you@email.com" required />
    <button type="submit">Subscribe</button>
  </form>
  <p class="nl-msg" id="nl-msg"></p>
</div>

<script>
  const form = document.getElementById('nl-form') as HTMLFormElement;
  const msg = document.getElementById('nl-msg')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button')!;
    btn.textContent = '...';
    btn.disabled = true;
    try {
      await fetch('https://app.kit.com/forms/9b34dfb969/subscriptions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email_address: new FormData(form).get('email_address') }),
      });
      form.style.display = 'none';
      msg.textContent = "You're in! Check your email to confirm.";
    } catch {
      btn.textContent = 'Subscribe';
      btn.disabled = false;
      msg.textContent = 'Something went wrong. Try again.';
    }
  });
</script>

<style>
  .newsletter {
    margin-top: 4rem;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-raised);
    text-align: center;
  }
  .newsletter h3 { margin-bottom: 0.5rem; font-size: 1.1rem; }
  .newsletter p { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.25rem; }
  .nl-form { display: flex; gap: 0.5rem; max-width: 400px; margin: 0 auto; }
  .nl-form input {
    flex: 1;
    padding: 0.6rem 0.8rem;
    font-size: 0.85rem;
    font-family: var(--font-body);
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    color: var(--text);
    outline: none;
  }
  .nl-form input:focus { border-color: var(--accent); }
  .nl-form button {
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 600;
    font-family: var(--font-body);
    background: var(--accent);
    color: var(--bg);
    border: none;
    border-radius: 4px;
    cursor: pointer;
  }
  .nl-form button:hover { opacity: 0.85; }
  .nl-form button:disabled { opacity: 0.5; cursor: not-allowed; }
  .nl-msg:empty { display: none; }
  .nl-msg { font-size: 0.85rem; margin-top: 0.75rem; color: var(--accent); }
  @media (max-width: 480px) { .nl-form { flex-direction: column; } }
</style>
