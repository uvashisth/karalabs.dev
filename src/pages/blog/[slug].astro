---
import BlogPost from '../../layouts/BlogPost.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog'))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  const published = allPosts.filter(p => !p.data.draft);
  return allPosts.map((post) => {
    const pubIndex = published.findIndex(p => p.id === post.id);
    return {
      params: { slug: post.id },
      props: {
        post,
        prev: pubIndex >= 0 ? (published[pubIndex + 1] ?? null) : null,
        next: pubIndex >= 0 ? (published[pubIndex - 1] ?? null) : null,
      },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);

const words = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = Math.max(1, Math.round(words / 200));
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  formatTag={post.data.formatTag}
  topicTag={post.data.topicTag}
  tags={post.data.tags}
  image={post.data.image}
  readingTime={readingTime}
  headings={headings}
  prev={prev ? { slug: prev.id, title: prev.data.title } : null}
  next={next ? { slug: next.id, title: next.data.title } : null}
  draft={post.data.draft}
  slug={post.id}
>
  <Content />
</BlogPost>
