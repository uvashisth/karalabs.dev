---
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((post) => ({
    ...post,
    readingTime: Math.max(1, Math.round((post.body?.split(/\s+/).filter(Boolean).length ?? 0) / 200)),
  }));

const featured = allPosts[0];
const posts = allPosts.slice(1);

const formatTags = ['All', 'Fundamentals', 'Comparison', 'Benchmark', 'Case Study', 'Build Log', 'Opinion', 'Open Source'];

const featuredDate = featured?.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title="Blog — Kara Labs" description="Technical deep-dives on AI agent systems. Benchmarks, comparisons, and implementation details.">
  <div class="blog-page">
    <header class="blog-header animate-in">
      <h1>Blog</h1>
      <p>Benchmarks, comparisons, and implementation details.</p>
    </header>

    <div class="search-wrap animate-in delay-1">
      <svg class="search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="search" id="search-input" class="search-input" placeholder="Search posts..." autocomplete="off" />
    </div>

    <nav class="categories animate-in delay-1" id="category-nav">
      {formatTags.map((tag) => (
        <button class:list={['cat-btn', { active: tag === 'All' }]} data-category={tag}>
          {tag}
        </button>
      ))}
    </nav>

    {featured && (
      <a href={`/blog/${featured.id}`} class="featured-post animate-in delay-2" id="featured-post" data-category={featured.data.formatTag} data-search={[featured.data.title, featured.data.description, ...featured.data.tags].join(' ').toLowerCase()}>
        {featured.data.image && (
          <div class="featured-image">
            <img src={featured.data.image} alt={featured.data.title} loading="eager" />
          </div>
        )}
        <div class="featured-content">
          <div class="featured-meta">
            <span class="featured-category">{featured.data.formatTag}</span>
            {featured.data.topicTag && <span class="featured-topic">{featured.data.topicTag}</span>}
            <span class="featured-date">{featuredDate}</span>
            <span class="featured-read">{featured.readingTime} min read</span>
          </div>
          <h2 class="featured-title">{featured.data.title}</h2>
          <p class="featured-desc">{featured.data.description}</p>
        </div>
      </a>
    )}

    <div class="posts-list animate-in delay-2" id="posts-list">
      {posts.map((post) => (
        <div class="post-item" data-category={post.data.formatTag} data-search={[post.data.title, post.data.description, ...post.data.tags].join(' ').toLowerCase()}>
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            formatTag={post.data.formatTag}
            topicTag={post.data.topicTag}
            slug={post.id}
            tags={post.data.tags}
            image={post.data.image}
            readingTime={post.readingTime}
          />
        </div>
      ))}
    </div>

    {allPosts.length === 0 && (
      <div class="empty">
        <p>No posts yet. First one coming soon.</p>
      </div>
    )}
    <div class="empty-filter" id="empty-filter" style="display:none">
      <p>No posts in this category yet.</p>
    </div>
  </div>
</Base>

<script>
  const nav = document.getElementById('category-nav');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const items = document.querySelectorAll('.post-item');
  const featured = document.getElementById('featured-post') as HTMLElement | null;
  const emptyFilter = document.getElementById('empty-filter');

  let currentCat = 'All';
  let currentQuery = '';

  function applyFilters() {
    nav?.querySelectorAll('.cat-btn').forEach((b) => b.classList.remove('active'));
    nav?.querySelector(`[data-category="${currentCat}"]`)?.classList.add('active');
    let visible = 0;

    if (featured) {
      const matchesCat = currentCat === 'All' || featured.dataset.category === currentCat;
      const matchesQuery = !currentQuery || (featured.dataset.search ?? '').includes(currentQuery);
      if (matchesCat && matchesQuery) {
        featured.style.display = '';
        visible++;
      } else {
        featured.style.display = 'none';
      }
    }

    items.forEach((item) => {
      const el = item as HTMLElement;
      const matchesCat = currentCat === 'All' || el.dataset.category === currentCat;
      const matchesQuery = !currentQuery || (el.dataset.search ?? '').includes(currentQuery);
      if (matchesCat && matchesQuery) {
        el.style.display = '';
        visible++;
      } else {
        el.style.display = 'none';
      }
    });
    if (emptyFilter) emptyFilter.style.display = visible === 0 ? '' : 'none';
  }

  const params = new URLSearchParams(window.location.search);
  const initialFilter = params.get('filter');
  if (initialFilter) { currentCat = initialFilter; }
  applyFilters();

  nav?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.cat-btn');
    if (!btn) return;
    currentCat = btn.getAttribute('data-category') || 'All';
    applyFilters();
  });

  searchInput?.addEventListener('input', () => {
    currentQuery = searchInput.value.trim().toLowerCase();
    applyFilters();
  });
</script>

<style>
  .blog-page { max-width: var(--max-width-wide); margin: 0 auto; padding: 3rem 1.5rem; }
  .blog-header { margin-bottom: 2rem; }
  .search-wrap {
    position: relative;
    margin-bottom: 1rem;
  }
  .search-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-dim);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 0.6rem 1rem 0.6rem 2.25rem;

    font-size: var(--font-size-2xs);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    outline: none;
    transition: border-color var(--transition);
  }
  .search-input::placeholder { color: var(--text-dim); }
  .search-input:focus { border-color: var(--border-accent); }
  .search-input::-webkit-search-cancel-button { cursor: pointer; }
  .blog-header h1 { margin-bottom: 0.5rem; }
  .blog-header p { color: var(--text-dim); }
  .categories {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .cat-btn {

    font-size: var(--font-size-3xs);
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 0.4rem 0.9rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all var(--transition);
  }
  .cat-btn:hover { border-color: var(--border-accent); color: var(--text-muted); }
  .cat-btn.active { background: var(--accent-glow); border-color: var(--accent); color: var(--accent); }
  .featured-post {
    display: block;
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: all var(--transition);
  }
  .featured-post:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }
  .featured-image {
    margin: -1.5rem -1.5rem 1.25rem;
    overflow: hidden;
    border-radius: var(--radius) var(--radius) 0 0;
  }
  .featured-image img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
    transition: transform var(--transition);
  }
  .featured-post:hover .featured-image img { transform: scale(1.02); }
  .featured-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
  .featured-category {
    font-size: var(--font-size-3xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .featured-topic {
    font-size: var(--font-size-3xs);
    font-weight: 500;
    color: var(--text-dim);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .featured-date, .featured-read { font-size: var(--font-size-2xs); color: var(--text-dim); }
  .featured-title {
    font-size: clamp(1.5rem, 2vw, 1.875rem);
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: var(--line-height-heading);
  }
  .featured-desc {
    font-size: var(--font-size-xs);
    color: var(--text-muted);
    line-height: var(--line-height-content);
    max-width: 640px;
  }
  .posts-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1rem; }
  .empty, .empty-filter { text-align: center; padding: 4rem 0; }
  .empty p, .empty-filter p { color: var(--text-dim); }
</style>
